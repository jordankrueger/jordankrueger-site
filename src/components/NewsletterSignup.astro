---
interface Props {
  variant?: 'default' | 'compact';
  id?: string;
}
const { variant = 'default', id = 'subscribe' } = Astro.props;
---

<div class:list={["newsletter-wrap", variant]} id={id}>
  <section class:list={["newsletter-panel", variant]}>
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <p class="newsletter-label">Subscribe to</p>
        <p class="newsletter-title">Mission Control ➡️</p>
        <hr class="newsletter-divider" />
      </div>
      <div class="newsletter-form-wrap">
        <p class="newsletter-desc">I share thoughts on online tools, learnings from my nonprofit advocacy consulting business, projects I'm launching, Artificial Intelligence, and personal updates — directly to your inbox.</p>
        <form method="post" action="https://progressives-signup.restless-salad-a31e.workers.dev" class="newsletter-form">
          <label class="sr-only">Email address</label>
          <input type="email" name="email" placeholder="Your email" required maxlength="256" />
          <input type="hidden" name="list" value="mission-control" />
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>
        <p class="newsletter-status" hidden></p>
      </div>
    </div>
  </section>
</div>

<style>
  /* Default variant: full-width band (no padding on wrap, border-top/bottom only) */
  .newsletter-wrap {
    padding: 0;
  }

  .newsletter-wrap.compact {
    padding: var(--spacing-md) var(--spacing-md);
  }

  .newsletter-panel {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--spacing-lg);
    background-color: var(--color-bg-warm);
  }

  .newsletter-panel.compact {
    max-width: var(--max-width);
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-peach);
  }

  .newsletter-inner {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    max-width: var(--max-width);
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .newsletter-text {
    flex: 1;
    min-width: 260px;
  }

  .newsletter-form-wrap {
    flex: 1;
    min-width: 280px;
  }

  .newsletter-label {
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .newsletter-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
  }

  .newsletter-divider {
    border: none;
    border-top: 2px solid var(--color-border);
    margin-top: var(--spacing-sm);
    width: 60px;
  }

  .newsletter-desc {
    font-size: 0.95rem;
    margin-bottom: var(--spacing-sm);
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter-form input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: var(--color-bg-white);
  }

  .newsletter-form input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: var(--color-accent);
  }

  .newsletter-status {
    font-size: 0.9rem;
    margin-top: 0.6rem;
    text-align: left;
  }

  .newsletter-status.success {
    color: #2d7a3a;
  }

  .newsletter-status.error {
    color: #c0392b;
  }

  @media (max-width: 640px) {
    .newsletter-wrap.compact {
      padding: var(--spacing-md) var(--spacing-sm);
    }

    .newsletter-panel {
      padding: var(--spacing-md) var(--spacing-lg);
    }

    .newsletter-panel.compact {
      padding: var(--spacing-md) var(--spacing-sm);
      border-radius: var(--radius-md);
    }

    .newsletter-inner {
      gap: var(--spacing-md);
    }

    .newsletter-form {
      flex-direction: column;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('form.newsletter-form').forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLParagraphElement>('.newsletter-status');
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const originalLabel = btn?.textContent ?? 'Subscribe';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !btn) return;

      btn.disabled = true;
      btn.textContent = 'Subscribing...';
      status.hidden = true;

      const data = Object.fromEntries(new FormData(form).entries());

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const body = await res.json();

        if (res.ok && body.success) {
          status.textContent = "You're on the list. Thanks!";
          status.className = 'newsletter-status success';
          status.hidden = false;
          form.reset();
        } else {
          status.textContent = body.error || 'Something went wrong. Please try again.';
          status.className = 'newsletter-status error';
          status.hidden = false;
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'newsletter-status error';
        status.hidden = false;
      }

      btn.disabled = false;
      btn.textContent = originalLabel;
    });
  });
</script>
