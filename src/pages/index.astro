---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ContactForm from '../components/ContactForm.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Jordan Krueger: Operations nerd, tech translator.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Jordan Krueger",
    "url": "https://jordankrueger.com",
    "jobTitle": "Founder & CEO",
    "worksFor": {
      "@type": "Organization",
      "name": "CampaignHelp"
    },
    "sameAs": [
      "https://bsky.app/profile/jordankrueger.com",
      "https://www.linkedin.com/in/jordankrueger/"
    ]
  })} />
  <Hero />

  <NewsletterSignup />

  <!-- Practices -->
  <h2 class="section-heading practices-heading fade-up">Two practices I run</h2>
  <div class="panel-wrap">
    <section class="ak-panel practice-diptych fade-up">
      <div class="diptych-grid">
        <div class="diptych-half">
          <span class="practice-kicker">My consultancy</span>
          <h3>CampaignHelp</h3>
          <p>Fractional tech and operations for progressive nonprofits. Whatever piece your team can't get to — websites, AI workflows, security setup, infrastructure rescue.</p>
          <div class="practice-services">
            <span class="pill">Websites</span>
            <span class="pill">AI workflows</span>
            <span class="pill">Security setup</span>
            <span class="pill">Fractional support</span>
          </div>
          <a href="https://campaign.help" target="_blank" rel="noopener" class="btn btn-primary practice-cta">See how I help →</a>
        </div>
        <div class="diptych-divider" aria-hidden="true"></div>
        <div class="diptych-half">
          <span class="practice-kicker gah">Coming soon · my second practice</span>
          <h3>Grounded AI</h3>
          <p>AI talks, workshops, and advisory for operations leaders at mid-sized nonprofits and associations. Launching later this summer.</p>
          <div class="practice-services">
            <span class="pill">Speaking</span>
            <span class="pill">Workshops</span>
            <span class="pill">Advisory</span>
          </div>
          <a href="https://groundedai.help" target="_blank" rel="noopener" class="btn btn-outline practice-cta">Get notified at launch →</a>
        </div>
      </div>
    </section>
  </div>

  <!-- About Preview -->
  <div class="panel-wrap">
    <section class="about-panel fade-up">
      <h2 class="about-heading">About me 🤔</h2>
      <hr class="section-rule about-rule" />
      <div class="about-body">
        <p>Hi, I'm Jordan. I run <a href="https://campaign.help">CampaignHelp</a>, where I help progressive nonprofits and advocacy organizations stop wrestling with their technology — ActionKit, Google Workspace, tool migrations, workflow automation, and everything in between.</p>
        <p>I've worked with Win Without War, 350.org, Color Of Change, MomsRising, and others. Nearly two decades in the progressive movement means I already know your tools, your campaign cycle, and your budget constraints.</p>
        <a href="/about" class="read-more">Read my full story →</a>
      </div>
    </section>
  </div>

  <!-- Recent Blog Posts -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading fade-up">My recent blog posts</h2>
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((post, i) => (
            <div class={`fade-up delay-${Math.min(i + 1, 4)}`}>
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                slug={post.id}
                coverImage={post.data.coverImage}
                tags={post.data.tags}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="placeholder-text">Blog posts coming soon. Stay tuned!</p>
      )}
      <div class="center-link fade-up">
        <a href="/blog" class="btn btn-outline">Read more</a>
      </div>
    </div>
  </section>

  <div class="fade-up">
    <ContactForm />
  </div>
</BaseLayout>

<style>
  :root {
    --color-gah-accent: #a4691f;
  }

  .section-heading {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .practices-heading {
    margin-top: var(--spacing-xl);
  }

  /* Bordered offset panels — the Carrd signature look */
  .panel-wrap {
    padding: 0 var(--spacing-md);
  }

  .ak-panel {
    max-width: var(--max-width);
    margin: var(--spacing-md) auto;
    background-color: var(--color-bg-peach);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
  }

  .about-panel {
    max-width: var(--max-width);
    margin: var(--spacing-md) auto;
    background-color: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
  }

  /* Practices diptych */
  .practice-diptych {
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .diptych-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    grid-template-rows: auto auto 1fr auto auto;
    column-gap: var(--spacing-xl);
    row-gap: 0.85rem;
  }

  .diptych-half {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: 1 / 6;
    gap: 0.85rem;
  }

  .diptych-half h3 {
    font-family: var(--font-heading);
    font-size: 1.85rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.1;
    margin: 0;
  }

  .diptych-half p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  .diptych-divider {
    background: var(--color-border);
    grid-row: 1 / -1;
    opacity: 0.7;
  }

  .practice-kicker {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    font-weight: 700;
    margin: 0;
  }
  .practice-kicker.gah {
    color: var(--color-gah-accent);
  }

  .practice-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }

  .practice-services .pill {
    font-size: 0.8rem;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    font-family: var(--font-body);
  }

  .practice-cta {
    margin-top: 0.3rem;
    justify-self: start;
    align-self: start;
    text-decoration: none;
  }

  /* Fallback for browsers without subgrid */
  @supports not (grid-template-rows: subgrid) {
    .diptych-half {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    .diptych-half p { flex: 1 0 auto; }
  }

  /* About Preview */
  .about-heading {
    text-align: center;
  }

  .about-rule {
    margin: 0 auto var(--spacing-md);
  }

  .about-body {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .read-more {
    display: inline-block;
    margin-top: var(--spacing-sm);
    font-weight: 500;
  }

  /* Posts Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .placeholder-text {
    text-align: center;
    color: var(--color-text-light);
    font-style: italic;
    margin-bottom: var(--spacing-md);
  }

  .center-link {
    text-align: center;
    margin-top: var(--spacing-md);
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .diptych-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      row-gap: var(--spacing-lg);
    }
    .diptych-half {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      grid-row: auto;
    }
    .diptych-divider {
      width: 100%;
      height: 1px;
      grid-row: auto;
    }
    .practice-diptych {
      padding: var(--spacing-lg);
    }
  }

  @media (max-width: 640px) {
    .ak-panel,
    .about-panel {
      padding: var(--spacing-md) var(--spacing-sm);
      border-radius: var(--radius-md);
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
